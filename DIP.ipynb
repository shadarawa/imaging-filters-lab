03e    \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eContrast Stretch\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e: dict(fn=lambda img, p: contrast_stretch(img, p[\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003er1\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e], p[\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003er2\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e]), params=[\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003er1\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003er2\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e]),\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eGray Slicing\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e: dict(fn=lambda img, p: gray_slice(img, p[\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ea\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e], p[\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eb\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e], p[\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ekeep\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e]), params=[\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ea\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eb\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003ekeep\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e]),\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u00