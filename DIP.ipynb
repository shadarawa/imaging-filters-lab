"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e,\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e        \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eSkeletonize (Thinning)\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    ],\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e    \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eBinary Set Ops\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e: [\u003cspan class=\"pl-cce\"\u003e\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e        \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eBinary Complement\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eBinary Union\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eBinary Intersection\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003e, \u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\u003c/span\u003eBinary Difference\u003cspan class=\"pl-cce\"\u003e\\\u0026quot;\\n\u003c/span\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u003c/span\u003e\u003c/span\u003e,","        \u003cspan class=\"pl-s\"\u003e\u003cspan class=\"pl-pds\"\u003e\u0026quot;\u00